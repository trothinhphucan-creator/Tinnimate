# ============================================================================
# TinniMate Server Environment Variables
# ============================================================================
# Copy this file to .env.production and fill in your actual values
# DO NOT commit .env.production to git
# ============================================================================

# Node environment
NODE_ENV=production

# ============================================================================
# Supabase Configuration
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ============================================================================
# LLM Provider API Keys
# ============================================================================
# Gemini (Google)
GEMINI_API_KEY=your-gemini-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================================================
# Database Configuration
# ============================================================================
DB_USER=postgres
DB_PASSWORD=your-secure-database-password
DB_NAME=tinnimate
DB_HOST=postgres
DB_PORT=5432

# ============================================================================
# Next.js Configuration
# ============================================================================
# Public site URL — required so OAuth callbacks redirect to the correct domain
# (not localhost:3000) when running behind Nginx/Cloudflare
NEXT_PUBLIC_SITE_URL=https://tinnimate.vuinghe.com

# ============================================================================
# Stripe Configuration
# ============================================================================
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# ============================================================================
# Security & Monitoring (Optional)
# ============================================================================
# Sentry for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Slack webhook for notifications
# SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# CORS Configuration (if needed)
# ============================================================================
# ALLOWED_ORIGINS=https://tinimate.vuinghe.com,https://admin.tinimate.vuinghe.com

# ============================================================================
# Facebook Social Listening (web → worker bridge)
# ============================================================================
# Worker URL — internal MiniPC. Admin web route handlers proxy calls here.
FB_WORKER_URL=http://localhost:4100
# Must match worker's WORKER_SHARED_SECRET
FB_WORKER_SHARED_SECRET=

# AgentSee Vector MCP (dùng từ web nếu cần grounding inline, vd preview reply)
AGENTSEE_MCP_URL=https://dashboard.vuinghe.com
AGENTSEE_INTERNAL_KEY=
